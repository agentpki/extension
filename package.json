{
  "name": "@agentpki/extension",
  "description": "AgentPKI — AI Agent Verification for Chrome. Detects AI agents on any webpage, verifies their cryptographic identity, surfaces a trust badge.",
  "version": "0.1.0-alpha.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@agentpki/sdk": "^0.1.0-alpha.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@wxt-dev/module-react": "1.1.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.6.2",
    "wxt": "0.19.29"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react": "^4.3.4"
    }
  }
}
